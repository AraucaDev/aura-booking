# ─────────────────────────────────────────────
# Aura Cleaners — Variables de entorno
# Copia este archivo a .env.local y completa los valores
# ─────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=https://booking.auracleaners.ca

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Stripe (modo test)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Google Calendar (cuenta de servicio)
GOOGLE_SERVICE_ACCOUNT_EMAIL=aura-calendar@tu-proyecto.iam.gserviceaccount.com
# Pega la private key entre comillas. Reemplaza saltos de línea reales por \n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=info@auracleaners.ca

# Resend
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Aura Cleaners <booking@auracleaners.ca>

# Notificaciones admin
ADMIN_NOTIFICATION_EMAIL=info@auracleaners.ca

# Zona horaria operativa
OPERATING_TIMEZONE=America/Toronto
